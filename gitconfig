[user]
	name = "Tejas Sanap"
	email = "tejas.sanap@beacon.io"
	signingkey = "~/.ssh/beacon2.pub"

[alias]
	unstage = restore --staged
	br = branch
	ch = checkout
	lo = log --oneline -n 20
	st = status
	diff = df
	df = difftool --staged
	ca = commit -a --amend --no-edit
	pu = push u
	puf = push u --force
	sl = stash list
	sd = stash drop

[branch]
	autoSetupMerge = always
	sort = -committerdate

[commit]
	gpgsign = true
	verbose = true

[credential "https://github.com"]
	username = whereistejas
	helper = keychain

[column]
	ui = auto

[core]
	excludesfile = "~/.gitignore"
	ignorecase = false

[diff]
	tool = difftastic
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[difftool]
	prompt = false

[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"

[fetch]
	prune = true
	pruneTags = true
	all = true

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = "~/.ssh/allowed_signers"

[mergetool]
	keepBackup = false

[protocol "file"]
	allow = always

[pager]
	difftool = true

[delta]
	features = gruvbox-light
	navigate = true
	light = true
	line-numbers = true
	hyperlinks = true

[delta "gruvbox-light"]
	syntax-theme = gruvbox-light
	light = true
	file-style = "#076678" bold
	file-decoration-style = "#076678" ul
	hunk-header-decoration-style = "#928374" box
	minus-style = syntax "#f2d6cd"
	minus-emph-style = syntax "#eaa9a0"
	plus-style = syntax "#e3e9c1"
	plus-emph-style = syntax "#c4cf95"
	zero-style = syntax
	line-numbers-minus-style = "#cc241d"
	line-numbers-plus-style = "#98971a"
	line-numbers-zero-style = "#928374"

[push]
	default = simple
	autoSetupRemote = true
	followTags = true

[help]
	autocorrect = prompt

[http]
	postBuffer = 157286400

[tag]
	sort = version:refname

[rerere]
	enabled = true
	autoupdate = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[remote "origin"]
	tagOpt = --no-tags
