#!/usr/bin/env bash
# Git credential helper backed by the macOS keychain `personal-tokens.*` namespace.
# Maps a git host to a keychain service name and returns the stored token.
# Only handles `get`; `store`/`erase` are no-ops (manage tokens with `security`).
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0

host=""
while IFS='=' read -r key value; do
	[ -z "$key" ] && break
	case "$key" in
	host) host="$value" ;;
	esac
done

case "$host" in
github.com) service="personal-tokens.github" ;;
*) exit 0 ;;
esac

token="$(security find-generic-password -s "$service" -w 2>/dev/null)" || exit 0
[ -n "$token" ] && printf 'password=%s\n' "$token"
exit 0
