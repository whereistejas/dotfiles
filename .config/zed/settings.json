{
	"agent": {
		"default_profile": "ask",
		"default_model": {
			"provider": "anthropic",
			"model": "claude-sonnet-4-5-thinking-latest"
		},
		"always_allow_tool_actions": true,
		"enabled": true
	},
	"base_keymap": "VSCode",
	"buffer_font_family": "Berkeley Mono",
	"buffer_font_size": 13,
	"collaboration_panel": {
		"button": true
	},
	"debugger": {
		"button": false
	},
	"git": {
		"inline_blame": {
			"delay_ms": 0,
			"enabled": true,
			"min_column": 0,
			"padding": 7,
			"show_commit_summary": true
		}
	},
	"git_panel": {
		"button": true
	},
	"hard_tabs": true,
	"tab_size": 4,
	"inlay_hints": {
		"enabled": false
	},
	"minimap": {
		"show": "never"
	},
	"preview_tabs": {
		"enabled": false
	},
	"search": {
		"button": false
	},
	"show_whitespaces": "all",
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"terminal": {
		"blinking": "on",
		"cursor_shape": "bar",
		"font_size": 13
	},
	"theme": {
		"dark": "One Dark",
		"light": "One Light",
		"mode": "light"
	},
	"ui_font_family": "SF Compact Display",
	"ui_font_size": 14,
	"vim_mode": true,
	"lsp": {
		"rust-analyzer": {
			"enable_lsp_tasks": true,
			"initialization_options": {
				"check": {
					"command": "clippy"
				},
				"diagnostics": {
					"styleLints": {
						"enable": true
					}
				}
			},
			"experimental": {
				"hoverActions": true
			}
		},
		"ocamllsp": {
			"settings": {
				"inlayHints": true,
				"syntaxDocumentation": true,
				"codelens": true,
				"extendedHover": true
			}
		}
	},
	"languages": { "Python": { "language_servers": ["!basedpyright"] } },
	"relative_line_numbers": true
}
