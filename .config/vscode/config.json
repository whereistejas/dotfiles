{
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[python]": {
		"editor.codeActionsOnSave": {
			"source.fixAll": "explicit",
			"source.organizeImports": "explicit",
		},
		"editor.defaultFoldingRangeProvider": "charliermarsh.ruff",
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true,
	},
	"[scss]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"[typescript]": {
		"editor.defaultFormatter": "vscode.typescript-language-features",
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"cursor.composer.textSizeScale": 1.15,
	"cursor.general.gitGraphIndexing": "enabled",
	"diffEditor.codeLens": true,
	"diffEditor.experimental.useTrueInlineView": true,
	"diffEditor.ignoreTrimWhitespace": true,
	"diffEditor.maxComputationTime": 0,
	"diffEditor.renderSideBySide": true,
	"editor.accessibilitySupport": "off",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.fontFamily": "Berkeley Mono",
	"editor.fontLigatures": true,
	"editor.fontSize": 14,
	"editor.formatOnSave": true,
	"editor.inlayHints.enabled": "offUnlessPressed",
	"editor.inlayHints.fontFamily": "Berkeley Mono",
	"editor.inlineSuggest.suppressSuggestions": true,
	"editor.insertSpaces": false,
	"editor.lightbulb.enabled": "off",
	"editor.renderWhitespace": "all",
	"editor.semanticHighlighting.enabled": true,
	"evenBetterToml.formatter.alignComments": false,
	"evenBetterToml.formatter.columnWidth": 120,
	"evenBetterToml.formatter.reorderKeys": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"files.associations": {
		"*.css": "tailwindcss",
	},
	"git.blame.editorDecoration.enabled": false,
	"git.blame.statusBarItem.enabled": true,
	"git.confirmSync": false,
	"git.ignoredRepositories": ["airbyte"],
	"git.openRepositoryInParentFolders": "never",
	"git.timeline.showUncommitted": true,
	"javascript.inlayHints.functionLikeReturnTypes.enabled": true,
	"javascript.inlayHints.parameterTypes.enabled": true,
	"javascript.inlayHints.propertyDeclarationTypes.enabled": true,
	"notebook.output.textLineLimit": 100,
	"prettier.useTabs": true,
	"remote.SSH.remotePlatform": {
		"magic-server": "linux",
	},
	"rust-analyzer.server.path": "/Users/whereistejas/.cargo/bin/rust-analyzer",
	"scm.inputFontFamily": "editor",
	"scm.inputFontSize": 14,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.profiles.linux": {
		"cargo": {
			"path": "cargo",
		},
	},
	"todohighlight.keywords": [
		{
			"text": "NOTE:",
		},
		{
			"text": "TODO:",
		},
		{
			"backgroundColor": "red",
			"color": "#fff",
			"text": "UNSAFE:",
		},
	],
	"typescript.inlayHints.enumMemberValues.enabled": true,
	"vim.cursorStylePerMode.insert": "line",
	"vim.cursorStylePerMode.normal": "block",
	"vim.enableNeovim": true,
	"vim.foldfix": true,
	"vim.highlightedyank.enable": true,
	"vim.neovimPath": "/opt/homebrew/bin/nvim",
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"after": ["^"],
			"before": ["0"],
		},
		{
			"after": ["$"],
			"before": ["9"],
		},
		{
			"after": ["g", "j"],
			"before": ["j"],
		},
		{
			"after": ["g", "k"],
			"before": ["k"],
		},
		{
			"after": ["$"],
			"before": ["4", "4"],
		},
	],
	"vim.smartRelativeLine": true,
	"vim.useSystemClipboard": true,
	"vim.visualstar": true,
	"window.zoomLevel": -0.4,
	"workbench.activityBar.orientation": "vertical",
	"workbench.colorTheme": "GitHub Light Default",
	"workbench.editor.enablePreview": false,
	"workbench.editor.revealIfOpen": true,
	"zenMode.hideLineNumbers": false,
	"zenMode.hideStatusBar": false,
	"cursorpyright.analysis.inlayHints.callArgumentNames": true,
	"python.pythonPath": "uv python",
	"vim.showMarksInGutter": true,
	"workbench.layoutControl.enabled": false,
	"files.autoSave": "afterDelay",
	"javascript.format.placeOpenBraceOnNewLineForControlBlocks": true,
}
