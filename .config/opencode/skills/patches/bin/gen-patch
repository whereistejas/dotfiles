#!/usr/bin/env bash
#
# gen-patch — Generate pasteable git-apply shell snippets from commits
#
# Extracts commits from a jj or git repo and produces self-contained bash
# snippets that can be pasted into a target git repo to replay them.
# Each snippet includes chain-of-trust safety checks and helpful error
# messages with abort instructions.
#
# Usage:
#   gen-patch pick <rev> [<rev> ...]    Specific commits (git SHAs or jj change IDs)
#   gen-patch branch [<name>]           All commits on a branch since trunk/main
#
# Options:
#   -R <path>    Repository path (default: current directory)
#   -h           Show this help
#
set -euo pipefail

PROG="gen-patch"
PROG_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
REPO_PATH="."
VCS=""       # "jj" or "git"
GIT_WORK=""  # path where git commands work (for tree hashes etc.)

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

die()  { printf '%s: \033[1;31merror:\033[0m %s\n' "$PROG" "$1" >&2; exit 1; }
info() { printf '%s\n' "$1" >&2; }
warn() { printf '%s: \033[1;33mwarn:\033[0m %s\n' "$PROG" "$1" >&2; }
bold() { printf '\033[1m%s\033[0m' "$1"; }

# ---------------------------------------------------------------------------
# VCS detection
# ---------------------------------------------------------------------------

detect_vcs() {
  if command -v jj >/dev/null 2>&1 && jj root -R "$REPO_PATH" >/dev/null 2>&1; then
    VCS="jj"
    # Need git for tree-hash lookups.  Works in colocated repos directly;
    # for non-colocated we fall back to the jj git root.
    if git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1; then
      GIT_WORK="$REPO_PATH"
    else
      local git_root
      git_root=$(jj git root -R "$REPO_PATH" 2>/dev/null) \
        || die "jj repo at $REPO_PATH has no git backend"
      GIT_WORK="$git_root"
    fi
  elif git -C "$REPO_PATH" rev-parse --git-dir >/dev/null 2>&1; then
    VCS="git"
    GIT_WORK="$REPO_PATH"
  else
    die "not a jj or git repository: $REPO_PATH"
  fi
}

# ---------------------------------------------------------------------------
# Git helpers (always available — used for tree hashes, parent lookups, etc.)
# ---------------------------------------------------------------------------

_git() { git -C "$GIT_WORK" "$@"; }

get_tree_hash() {
  _git rev-parse "${1}^{tree}" 2>/dev/null \
    || die "cannot get tree hash for: ${1:0:12}"
}

get_parent_sha() {
  _git rev-parse "${1}^" 2>/dev/null \
    || die "cannot get parent for: ${1:0:12}"
}

# ---------------------------------------------------------------------------
# Data extraction — VCS-agnostic interface
# ---------------------------------------------------------------------------

# Resolve an arbitrary revision (git SHA, short SHA, jj change ID) to a
# full 40-char git commit hash.
resolve_to_git_sha() {
  local rev="$1"
  if [ "$VCS" = "jj" ]; then
    # Try jj first (handles change IDs, bookmarks, revsets), fall back to git
    # (handles HEAD, refs, short SHAs that jj might not recognise).
    jj log -r "$rev" --no-graph -T 'commit_id' -R "$REPO_PATH" --color never 2>/dev/null \
      || _git rev-parse --verify "${rev}^{commit}" 2>/dev/null \
      || die "cannot resolve revision: $rev"
  else
    _git rev-parse --verify "${rev}^{commit}" 2>/dev/null \
      || die "cannot resolve revision: $rev"
  fi
}

# Full commit message (may be multi-line).
get_description() {
  local sha="$1"
  if [ "$VCS" = "jj" ]; then
    jj log -r "$sha" --no-graph -T 'description' -R "$REPO_PATH" --color never 2>/dev/null
  else
    _git log -1 --format='%B' "$sha" 2>/dev/null
  fi
}

# First line of the commit message.
get_subject() {
  local desc
  desc=$(get_description "$1")
  printf '%s' "$desc" | head -1
}

# Git-format diff for a single commit vs its parent.
get_diff() {
  local sha="$1"
  if [ "$VCS" = "jj" ]; then
    jj diff -r "$sha" --git -R "$REPO_PATH" --no-pager --color never 2>/dev/null
  else
    _git diff-tree -p --no-commit-id --find-renames --no-color "$sha" 2>/dev/null
  fi
}

# ---------------------------------------------------------------------------
# Branch helpers
# ---------------------------------------------------------------------------

# Return the git SHA of the trunk / main commit.
find_trunk_sha() {
  if [ "$VCS" = "jj" ]; then
    jj log -r 'trunk()' --no-graph -T 'commit_id' -R "$REPO_PATH" --color never 2>/dev/null \
      || die "cannot resolve trunk()"
  else
    local ref
    for ref in main master origin/main origin/master; do
      if _git rev-parse --verify "$ref" >/dev/null 2>&1; then
        _git rev-parse "$ref"
        return 0
      fi
    done
    die "cannot find trunk branch (tried: main, master, origin/main, origin/master)"
  fi
}

# List non-trunk bookmarks / branches the user can choose from.
list_branches() {
  if [ "$VCS" = "jj" ]; then
    jj bookmark list -R "$REPO_PATH" --color never 2>/dev/null \
      | awk '{print $1}' | sort
  else
    _git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null \
      | sort
  fi
}

# List commits (as git SHAs, oldest-first) on a branch since trunk.
list_branch_commits() {
  local branch="$1"
  if [ "$VCS" = "jj" ]; then
    jj log -r "trunk()..${branch}" --no-graph --reversed \
      -T 'commit_id ++ "\n"' -R "$REPO_PATH" --color never 2>/dev/null \
      || die "cannot list commits for branch: $branch"
  else
    local trunk_sha base_sha
    trunk_sha=$(find_trunk_sha)
    base_sha=$(_git merge-base "$trunk_sha" "$branch" 2>/dev/null) \
      || die "cannot find merge base between trunk and $branch"
    _git rev-list --reverse "${base_sha}..${branch}" 2>/dev/null \
      || die "cannot list commits for branch: $branch"
  fi
}

# ---------------------------------------------------------------------------
# Heredoc-delimiter safety
# ---------------------------------------------------------------------------

# Pick a heredoc delimiter that does not appear as a line in $content.
safe_delimiter() {
  local content="$1"
  local base="$2"
  local delim="$base"
  while printf '%s' "$content" | grep -qxF "$delim"; do
    delim="${base}_$(openssl rand -hex 4 2>/dev/null || echo $$)"
  done
  printf '%s' "$delim"
}

# ---------------------------------------------------------------------------
# Snippet generation
# ---------------------------------------------------------------------------

# Emit a self-contained bash snippet for one commit.
# Output goes to stdout; caller captures it.
#
# Args: sha index total is_first base_sha prev_tree_hash source_name
generate_snippet() {
  local sha="$1" index="$2" total="$3" is_first="$4"
  local base_sha="$5" prev_tree_hash="$6" source_name="${7:-}"

  local subject diff description patch_delim msg_delim
  subject=$(get_subject "$sha")
  diff=$(get_diff "$sha")
  description=$(get_description "$sha")
  # strip trailing whitespace from description
  description=$(printf '%s' "$description" | sed -e 's/[[:space:]]*$//')

  if [ -z "$diff" ]; then
    warn "empty diff for ${sha:0:12} ($subject), skipping"
    return 1
  fi

  patch_delim=$(safe_delimiter "$diff" "JJ_PATCH_EOF")
  msg_delim=$(safe_delimiter "$description" "JJ_MSG_EOF")

  # Escape single quotes for embedding in single-quoted bash strings
  local esc_subj="${subject//\'/\'\\\'\'}"
  local esc_source="${source_name//\'/\'\\\'\'}"

  # For the first patch, resolve the base commit's subject line so error
  # messages can show what commit the user should be on.
  local base_subject="" esc_base_subj=""
  if [ "$is_first" = "1" ]; then
    base_subject=$(get_subject "$base_sha")
    esc_base_subj="${base_subject//\'/\'\\\'\'}"
  fi

  # --- header comment ---
  printf '# [%d/%d] %s\n' "$index" "$total" "$subject"
  if [ "$is_first" = "1" ]; then
    printf '# Source: %s | Base: %s' "${sha:0:12}" "${base_sha:0:12}"
    [ -n "$source_name" ] && printf ' | Branch: %s' "$source_name"
    printf '\n'
  else
    printf '# Source: %s | Expected parent tree: %s\n' "${sha:0:12}" "${prev_tree_hash:0:12}"
  fi

  # --- subshell open + context variables + _fail function ---
  printf '%s\n' '('
  printf '%s\n' 'set -euo pipefail'
  printf '%s\n' '_applied=0'
  printf '_label="[%d/%d]"\n' "$index" "$total"
  if [ "$is_first" = "1" ]; then
    printf "_base_subj='%s'\n" "$esc_base_subj"
  fi
  if [ -n "$source_name" ]; then
    printf "_source='%s'\n" "$esc_source"
  fi
  printf '%s\n' '_fail() {'
  printf '%s\n' '  printf '"'"'\033[1;31mERROR %s:\033[0m %s\n'"'"' "$_label" "$1"'
  printf '%s\n' '  if [ "$_applied" -eq 1 ]; then'
  printf '%s\n' '    printf '"'"'\033[1;33mABORT:\033[0m To undo, run: git reset --hard HEAD\n'"'"''
  printf '%s\n' '  fi'
  printf '%s\n' '  exit 1'
  printf '%s\n' '}'
  printf '\n'

  # --- git repo check ---
  printf '%s\n' 'git rev-parse --git-dir >/dev/null 2>&1 \'
  printf '%s\n' '  || _fail "Not inside a git repository. cd into the target repo first."'
  printf '\n'

  # --- chain-of-trust check ---
  if [ "$is_first" = "1" ]; then
    printf '%s\n' '_head=$(git rev-parse HEAD)'
    printf '_expected="%s"\n' "$base_sha"
    printf '%s\n' '[ "$_head" = "$_expected" ] \'
    printf '%s' '  || _fail "HEAD is ${_head:0:12} but patches expect base commit ${_expected:0:12} (${_base_subj}).'
    printf '\n'
    if [ -n "$source_name" ]; then
      printf '%s\n' '  Source branch: ${_source}'
    fi
    printf '%s\n' '  Run: git log --oneline -5"'
  else
    printf '%s\n' '_tree=$(git rev-parse '"'"'HEAD^{tree}'"'"')'
    printf '_expected="%s"\n' "$prev_tree_hash"
    printf '%s\n' '[ "$_tree" = "$_expected" ] \'
    printf '%s\n' '  || _fail "Tree hash is ${_tree:0:12} but expected ${_expected:0:12} after the previous patch.'
    printf '%s\n' '  The previous patch may not have been applied or was modified after applying.'
    printf '%s\n' '  Run: git log --oneline -3"'
  fi
  printf '\n'

  # --- clean working-tree check ---
  printf '%s\n' 'git diff-index --quiet HEAD -- 2>/dev/null \'
  printf '%s\n' '  || _fail "Working tree has uncommitted changes. Commit or stash them first.'
  printf '%s\n' '  Run: git stash    (to stash changes)'
  printf '%s\n' '    or git status   (to inspect)"'
  printf '\n'

  # --- apply patch ---
  printf '%s\n' '_apply_err="Patch failed to apply cleanly.'
  printf '%s\n' '  The diff could not be applied to the current working tree.'
  printf '%s\n' '  This usually means the target files have diverged from the expected state.'
  printf '%s\n' '  Run: git status   (to inspect working tree)"'
  printf 'git apply --index <<'"'"'%s'"'"' || _fail "$_apply_err"\n' "$patch_delim"
  printf '%s\n' "$diff"
  printf '%s\n' "$patch_delim"
  printf '%s\n' '_applied=1'
  printf '\n'

  # --- commit ---
  printf '%s\n' '_commit_err="git commit failed.'
  printf '%s\n' '  The patch was staged but the commit could not be created.'
  printf '%s\n' '  A pre-commit hook may have rejected it, or the index may be empty.'
  printf '%s\n' '  Run: git status   (to inspect)"'
  printf 'git commit -F - <<'"'"'%s'"'"' || _fail "$_commit_err"\n' "$msg_delim"
  printf '%s\n' "$description"
  printf '%s\n' "$msg_delim"
  printf '\n'

  # --- success message ---
  printf "_ok='[%d/%d] %s'\n" "$index" "$total" "$esc_subj"
  printf '%s\n' 'printf '"'"'\033[1;32mOK:\033[0m %s\n'"'"' "$_ok"'
  printf '%s\n' ')'
}

# ---------------------------------------------------------------------------
# Batch snippet generation
# ---------------------------------------------------------------------------

# Wrap multiple individual snippets into a single script.
#
# Args: shas_nameref base_sha [source_name]
generate_batch_snippet() {
  local -n _shas=$1  # nameref to array of SHAs
  local total=${#_shas[@]}
  local base_sha="$2"
  local source_name="${3:-}"

  local base_subject
  base_subject=$(get_subject "$base_sha")

  printf '#!/usr/bin/env bash\n'
  printf '# %s batch — %d patch(es)\n' "$PROG_PATH" "$total"
  if [ -n "$source_name" ]; then
    printf '# Source branch: %s\n' "$source_name"
  fi
  printf '# Base commit:   %s %s\n' "${base_sha:0:12}" "$base_subject"
  printf '# Generated:     %s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '#\n'
  printf '# Paste this entire script into a terminal inside the target git repo.\n'
  printf '# It will apply all patches sequentially, stopping on the first error.\n'
  printf '#\n'
  printf '(\n'
  printf 'set -euo pipefail\n'
  printf '\n'

  local prev_tree_hash=""
  for i in "${!_shas[@]}"; do
    local sha="${_shas[$i]}"
    local index=$((i + 1))
    local is_first="0"
    [ "$i" -eq 0 ] && is_first="1"

    local snippet
    snippet=$(generate_snippet "$sha" "$index" "$total" "$is_first" "$base_sha" "$prev_tree_hash" "$source_name") \
      || continue

    printf '%s\n\n' "$snippet"

    prev_tree_hash=$(get_tree_hash "$sha")
  done

  printf 'printf '"'"'\\n\\033[1;32mAll %d patch(es) applied successfully.\\033[0m\\n'"'"'\n' "$total"
  printf ')\n'
}

# ---------------------------------------------------------------------------
# Interactive clipboard flow
# ---------------------------------------------------------------------------

copy_and_prompt() {
  local snippet="$1" index="$2" total="$3" subject="$4"

  printf '%s' "$snippet" | pbcopy

  if [ "$index" -lt "$total" ]; then
    info ""
    info "  Patch ${index}/${total}: ${subject}"
    info "  Copied to clipboard. Press Enter for next, q to quit..."
    local response
    read -r response
    if [ "$response" = "q" ] || [ "$response" = "Q" ]; then
      info "Aborted."
      exit 0
    fi
  else
    info ""
    info "  Patch ${index}/${total}: ${subject}"
    info "  Copied to clipboard. Done."
  fi
}

# ---------------------------------------------------------------------------
# Mode selection prompt
# ---------------------------------------------------------------------------

# Ask the user whether they want interactive (one-at-a-time) or batch mode.
# Returns "interactive" or "batch" on stdout.
prompt_mode() {
  local total="$1"
  info ""
  info "$(bold "How do you want the patches?")"
  info ""
  info "  1) One at a time  — copy each patch to clipboard, press Enter for next"
  info "  2) All at once    — single script with all ${total} patches, copied to clipboard"
  info ""
  printf '  Choose [1/2]: ' >&2
  local choice
  read -r choice
  case "$choice" in
    2) printf 'batch'  ;;
    *) printf 'interactive' ;;
  esac
}

# ---------------------------------------------------------------------------
# Branch selection prompt
# ---------------------------------------------------------------------------

# Show available branches and let the user pick one.  Falls back to the
# provided $1 if a name was already given on the command line.
prompt_branch() {
  local requested="$1"

  # If the user already supplied a branch name, use it.
  if [ -n "$requested" ]; then
    printf '%s' "$requested"
    return 0
  fi

  local branches_str
  branches_str=$(list_branches)

  if [ -z "$branches_str" ]; then
    die "no branches/bookmarks found in the repository"
  fi

  # Build an array from the branch list
  local branches=()
  while IFS= read -r line; do
    [ -n "$line" ] && branches+=("$line")
  done <<< "$branches_str"

  if [ "${#branches[@]}" -eq 0 ]; then
    die "no branches/bookmarks found in the repository"
  fi

  info ""
  info "$(bold "Available branches:")"
  info ""
  local idx=1
  for b in "${branches[@]}"; do
    printf '  %d) %s\n' "$idx" "$b" >&2
    idx=$((idx + 1))
  done
  info ""
  printf '  Enter number or branch name: ' >&2

  local choice
  read -r choice

  # If the choice is a number, map it to a branch name
  if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#branches[@]}" ]; then
    printf '%s' "${branches[$((choice - 1))]}"
  else
    printf '%s' "$choice"
  fi
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_pick() {
  local revs=("$@")
  [ "${#revs[@]}" -gt 0 ] || die "pick requires at least one revision"

  # Resolve all revisions to git SHAs
  local shas=()
  for rev in "${revs[@]}"; do
    local sha
    sha=$(resolve_to_git_sha "$rev")
    shas+=("$sha")
  done

  local total=${#shas[@]}
  info "Resolved ${total} commit(s)"

  # Show a summary
  for i in "${!shas[@]}"; do
    local sha="${shas[$i]}"
    local subj
    subj=$(get_subject "$sha")
    printf '  %d) %s %s\n' "$((i + 1))" "${sha:0:12}" "$subj" >&2
  done

  # Base = parent of the first commit
  local base_sha
  base_sha=$(get_parent_sha "${shas[0]}")

  # Choose mode
  local mode="interactive"
  if [ "$total" -gt 1 ]; then
    mode=$(prompt_mode "$total")
  fi

  if [ "$mode" = "batch" ]; then
    local batch
    batch=$(generate_batch_snippet shas "$base_sha" "")
    printf '%s' "$batch" | pbcopy
    info ""
    info "  All ${total} patches copied to clipboard as a single script. Done."
  else
    # Interactive: one at a time
    local prev_tree_hash=""
    for i in "${!shas[@]}"; do
      local sha="${shas[$i]}"
      local index=$((i + 1))
      local is_first="0"
      [ "$i" -eq 0 ] && is_first="1"

      local snippet
      snippet=$(generate_snippet "$sha" "$index" "$total" "$is_first" "$base_sha" "$prev_tree_hash" "") \
        || continue

      local subject
      subject=$(get_subject "$sha")
      copy_and_prompt "$snippet" "$index" "$total" "$subject"

      prev_tree_hash=$(get_tree_hash "$sha")
    done
  fi
}

cmd_branch() {
  local requested="${1:-}"

  # Let the user pick a branch (shows list if none provided)
  local branch
  branch=$(prompt_branch "$requested")
  [ -n "$branch" ] || die "no branch selected"

  info "Using branch: ${branch}"

  # Collect commits
  local commits_str
  commits_str=$(list_branch_commits "$branch")
  if [ -z "$commits_str" ]; then
    die "no commits found on branch '${branch}' since trunk"
  fi

  local shas=()
  while IFS= read -r line; do
    [ -n "$line" ] && shas+=("$line")
  done <<< "$commits_str"

  local total=${#shas[@]}
  info "Found ${total} commit(s) on branch '${branch}'"

  # Show a summary
  for i in "${!shas[@]}"; do
    local sha="${shas[$i]}"
    local subj
    subj=$(get_subject "$sha")
    printf '  %d) %s %s\n' "$((i + 1))" "${sha:0:12}" "$subj" >&2
  done

  # Base = parent of the first commit on the branch
  local base_sha
  base_sha=$(get_parent_sha "${shas[0]}")

  # Choose mode
  local mode="interactive"
  if [ "$total" -gt 1 ]; then
    mode=$(prompt_mode "$total")
  fi

  if [ "$mode" = "batch" ]; then
    local batch
    batch=$(generate_batch_snippet shas "$base_sha" "$branch")
    printf '%s' "$batch" | pbcopy
    info ""
    info "  All ${total} patches copied to clipboard as a single script. Done."
  else
    local prev_tree_hash=""
    for i in "${!shas[@]}"; do
      local sha="${shas[$i]}"
      local index=$((i + 1))
      local is_first="0"
      [ "$i" -eq 0 ] && is_first="1"

      local snippet
      snippet=$(generate_snippet "$sha" "$index" "$total" "$is_first" "$base_sha" "$prev_tree_hash" "$branch") \
        || continue

      local subject
      subject=$(get_subject "$sha")
      copy_and_prompt "$snippet" "$index" "$total" "$subject"

      prev_tree_hash=$(get_tree_hash "$sha")
    done
  fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  cat >&2 <<EOF
Usage: $PROG [-R <repo-path>] <command> [args...]

Commands:
  pick <rev> [<rev> ...]    Generate patches for specific commits
  branch [<name>]           Generate patches for all commits on a branch
                            (lists branches to choose from if name omitted)

Options:
  -R <path>    Repository path (default: current directory)
  -h           Show this help

Examples:
  $PROG pick abc123 def456
  $PROG pick xyzwvut              # jj change ID (if jj is available)
  $PROG branch                    # shows branch picker
  $PROG branch whereistejas.my-feature
  $PROG -R ~/code/myrepo branch feature/foo
EOF
  exit 1
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  while [ $# -gt 0 ]; do
    case "$1" in
      -R)
        [ $# -ge 2 ] || die "-R requires a path argument"
        REPO_PATH="$2"
        shift 2
        ;;
      -h|--help)
        usage
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        break
        ;;
    esac
  done

  [ $# -gt 0 ] || usage

  local cmd="$1"
  shift

  detect_vcs
  info "Using VCS: $VCS (repo: $REPO_PATH)"

  case "$cmd" in
    pick)   cmd_pick "$@"   ;;
    branch) cmd_branch "$@" ;;
    *)      die "unknown command: $cmd (try 'pick' or 'branch')" ;;
  esac
}

main "$@"
